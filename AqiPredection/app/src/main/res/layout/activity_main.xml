<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F8F9FA"
    android:layout_marginTop="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AQI Predictor"
        android:textSize="24sp"
        android:textColor="#1A237E"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/city_spinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- City Dropdown -->
    <Spinner
        android:id="@+id/city_spinner"
        android:layout_width="0dp"
        android:layout_height="40dp"
        app:layout_constraintTop_toBottomOf="@id/title_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Enhanced Date Picker Section with CardView -->
    <androidx.cardview.widget.CardView
        android:id="@+id/date_picker_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/city_spinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/predict_button">

        <!-- DatePicker inside the CardView -->
        <DatePicker
            android:id="@+id/date_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="?android:attr/selectableItemBackground" />
    </androidx.cardview.widget.CardView>

    <!-- Predict AQI Button -->
    <Button
        android:id="@+id/predict_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Predict AQI"
        android:backgroundTint="#1A73E8"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/date_picker_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Real-Time AQI Button -->
    <Button
        android:id="@+id/real_time_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get Real-Time AQI"
        android:backgroundTint="#43A047"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/predict_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Predicted AQI Result -->
    <TextView
        android:id="@+id/predicted_result_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Predicted AQI will appear here"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/real_time_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Real-Time AQI Result -->
    <TextView
        android:id="@+id/real_time_result_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Real-Time AQI will appear here"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/predicted_result_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
